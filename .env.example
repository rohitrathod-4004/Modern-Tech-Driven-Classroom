# Global Environment Variables for AI Classroom Platform

# ── Gemini AI Credentials ──────────────────────────────────
# Required: Paste your Gemini API key here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Services Ports (Host bindings) ──────────────────────────
PORT_BACKEND=3001
PORT_FRONTEND=5173
PORT_WHISPER=8000
PORT_QDRANT=6333
PORT_MONGODB=27017

# ── Service API URLs ────────────────────────────────────────
# Used by Vite (frontend) to hit backend
VITE_API_URL=http://localhost:3001
